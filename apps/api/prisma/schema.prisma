// Gusto schema.
// M0: auth. M1: chef profile + menu (below). M2: favorites. M3: orders/payments.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  CHEF
  ADMIN
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

model User {
  id          String   @id @default(cuid())
  phone       String   @unique
  displayName String?
  roles       UserRole[] @default([CUSTOMER])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  devices       Device[]
  refreshTokens RefreshToken[]
  chefProfile   ChefProfile?
  favorites     Favorite[]
}

model Device {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform   DevicePlatform
  pushToken  String?
  lastSeenAt DateTime       @default(now())

  refreshTokens RefreshToken[]

  @@unique([userId, id])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId  String?
  device    Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  // sha-256 of the opaque refresh token; raw token never stored.
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  // set when this token is rotated out; presence + a later use = reuse attack.
  rotatedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ── M1: chef profile + menu ──────────────────────────────────────────────

model ChefProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String @default("")
  kitchenName String @default("")
  bio         String @default("")
  selfieUrl   String @default("")
  timelineUrl String @default("")

  // address
  addressLine1 String  @default("")
  addressLine2 String?
  city         String  @default("")
  region       String?
  postalCode   String?
  country      String  @default("IL")

  // geocoded kitchen location (for distance to customers)
  lat Float @default(32.0853)
  lng Float @default(34.7818)

  onboarded       Boolean @default(false)
  verified        Boolean @default(false)
  active          Boolean @default(false)
  acceptingOrders Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dishes       Dish[]
  availability Availability[]
  favoritedBy  Favorite[]
}

model Dish {
  id            String      @id @default(cuid())
  chefProfileId String
  chef          ChefProfile @relation(fields: [chefProfileId], references: [id], onDelete: Cascade)

  name        String
  description String  @default("")
  price       Float
  currency    String  @default("ILS")
  imageUrl    String?
  available   Boolean @default(true)

  category    String?
  prepMinutes Int?
  kosher      Boolean  @default(false)
  diets       String[]
  allergens   String[]

  rating      Float @default(0)
  ratingCount Int   @default(0)

  createdAt DateTime @default(now())

  @@index([chefProfileId])
}

// Weekly capacity windows (e.g. Sun 08:00–14:00, max 10 orders).
model Availability {
  id            String      @id @default(cuid())
  chefProfileId String
  chef          ChefProfile @relation(fields: [chefProfileId], references: [id], onDelete: Cascade)

  weekday   Int // 0 = Sunday … 6 = Saturday
  startTime String // "08:00"
  endTime   String // "14:00"
  maxOrders Int    @default(10)

  @@index([chefProfileId])
}

// ── M2: favorites ────────────────────────────────────────────────────────

model Favorite {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  chefProfileId String
  chef          ChefProfile @relation(fields: [chefProfileId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([userId, chefProfileId])
  @@index([userId])
}
