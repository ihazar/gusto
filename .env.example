# ── API ────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=5000

# Postgres (matches docker-compose.yml host port)
DATABASE_URL=postgresql://hearth:hearth@localhost:5003/hearth?schema=public

# Redis (OTP rate-limiting, BullMQ later)
REDIS_URL=redis://localhost:5004

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900          # seconds (15 min)
JWT_REFRESH_TTL=2592000     # seconds (30 days)

# OTP provider: "mock" (logs code, no SMS) or "twilio"
OTP_PROVIDER=mock
OTP_CODE_TTL=300            # seconds (5 min)
OTP_MAX_ATTEMPTS=5
OTP_REQUEST_WINDOW=3600     # seconds
OTP_MAX_REQUESTS_PER_WINDOW=5

# Twilio Verify (only needed when OTP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ── Clients ────────────────────────────────────────────────────────────
# Angular: apps/web/src/environments/*
# Expo:    apps/mobile/.env -> EXPO_PUBLIC_API_URL
EXPO_PUBLIC_API_URL=http://localhost:5000
